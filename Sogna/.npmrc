# ==============================================================================
# SOGNA: PNPM Engine Configuration (.npmrc)
# ==============================================================================
# Este archivo define las leyes inmutables del gestor de dependencias.
# Asegura eficiencia máxima, resolución estricta y previene conflictos fantasma.

# 1. Resolución Automática y Tolerancia
# Instala automáticamente dependencias 'peer' faltantes (resuelve el 90% de los warnings).
auto-install-peers=true
# Evita que el sistema colapse por discrepancias menores de dependencias 'peer'.
strict-peer-dependencies=false

# 2. Arquitectura de Aislamiento
# Fuerza la estructura de enlaces simbólicos (symlinks) aislados. 
# Previene la infestación cruzada de paquetes (Phantom Dependencies).
node-linker=isolated

# 2b. Workspace anidado (Predatore ⊂ Curator depende de @Sogna/Curator)
# Sin inject, pnpm crea junction al árbol fuente → recursión infinita en Windows/git.
inject-workspace-packages=true
dedupe-injected-deps=true

# 3. Elevación Estratégica (Hoisting)
# Permite que herramientas globales (como eslint o vite) se expongan en la raíz 
# para facilitar el acceso a scripts e IDEs, sin comprometer el aislamiento general.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*vite*
public-hoist-pattern[]=*turbo*
