{
  "name": "sogna-monorepo",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Sogna  Ecosystem - Orchestrated by Turbo",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "graph": "turbo run build --graph",
    "prepare": "cd .. && husky Sogna/Curator/engines/Sentinel/.husky",
    "sogna": "node Curator/bin/sogna.js",
    "dream": "node Curator/bin/dream.js",
    "sognatore": "node Curator/bin/sognatore.js",
    "sync": "node Curator/bin/memory_sync.js",
    "dev": "vite"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "**/*.{ts,js}": [
      "node Curator/engines/Sentinel/bin/sentinel-veto.js"
    ],
    "Curator/engines/Sentinel/.husky/*": [
      "node Curator/engines/Sentinel/bin/sentinel-veto.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "chalk": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "rimraf": "^6.0.1",
    "rollup": "^4.34.8",
    "concurrently": "^9.1.2",
    "jest": "^29.7.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-terser": "^0.4.4",
    "rollup-plugin-sourcemaps": "^0.6.3",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-preserve-directives": "^0.4.0"
  }
}
