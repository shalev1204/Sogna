{
"name": "sogna",
  "version": "0.1.0",
  "slogan": "Build for the Second One",
  "type": "module",
  "private": true,
  "sogna_governance": "./.sognarc.json",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "prepare": "git config core.hooksPath .veglia",
    "sogna:dev": "turbo run dev --filter=@Sogna/web",
    "sogna:start": "pnpm --filter=@Sogna/web start",
    "sogna:dream": "node Curator/bin/dream.js",
    "sognatore:core": "node Curator/bin/sognatore.js",
    "sentinel:audit": "python Curator/engines/Sentinel/sentinel-doctor.py",
    "sentinel:veto": "node Curator/engines/Sentinel/bin/Sentinel-veto.js",
    "memory:sync": "node Curator/bin/memory_sync.js",
    "postinstall": "node Curator/scripts/node_sanitizer.js"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "**/*.{ts,js}": [
      "pnpm sentinel:veto"
    ],
    ".veglia/*": [
      "pnpm sentinel:veto"
    ]
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": "^7.0.3",
      "@anthropic-ai/sdk": ">=0.91.1",
      "esbuild@<=0.24.2": ">=0.25.0",
      "prismjs@<1.30.0": ">=1.30.0",
      "postcss@<8.5.10": ">=8.5.10",
      "rollup-plugin-sourcemaps>rollup": ">=4.0.0",
      "@anthropic-ai/claude-agent-sdk>zod": ">=3.25.76"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "rollup"
      ],
      "allowedVersions": {
        "rollup-plugin-sourcemaps": "*"
      }
    }
  },
  "devDependencies": {
    "lint-staged": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
