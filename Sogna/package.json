{
  "name": "sogna",
  "version": "institutional",
  "slogan": "Build for the Second One",
  "type": "module",
  "private": true,
  "sogna_governance": "./.sognarc.json",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "prepare": "git config core.hooksPath .veglia",
    "sogna:dev": "turbo run dev --filter=@Sogna/web",
    "sogna:start": "pnpm --filter=@Sogna/web start",
    "sogna:dream": "node scripts/sogna-dream.mjs",
    "sogna:git-sync": "node scripts/sogna-sync.mjs",
    "env:organize": "node scripts/env-organize.mjs",
    "env:check": "node scripts/env-organize.mjs --dry-run",
    "sogna:world": "node Curator/bin/dream.js",
    "chroma:index": "node scripts/vector-bootstrap.mjs",
    "vector:index": "node scripts/vector-bootstrap.mjs",
    "supabase:setup": "node scripts/supabase-setup.mjs",
    "supabase:schema": "node scripts/supabase-schema.mjs",
    "supabase:migrate": "node scripts/supabase-migrate.mjs",
    "supabase:verify": "node scripts/supabase-setup.mjs",
    "sognatore:core": "node Curator/bin/sognatore.js",
    "sognatore:watch:signatures": "pnpm --filter Sognatore watch:signatures",
    "sentinel:audit": "node scripts/python-run.mjs Sentinel/Sentinel-doctor.py",
    "sentinel:veto": "node Sentinel/bin/sentinel-veto.js",
    "sentinel:resign": "node Sentinel/bin/sentinel-resign-all.js",
    "memory:sync": "node Curator/bin/memory_sync.js",
    "sogna:pulse": "node Curator/bin/pulse.js",
    "verify:p0": "pnpm --filter Sognatore verify:p0",
    "verify:p4": "pnpm --filter Sognatore verify:p4",
    "mcp:config": "node scripts/python-run.mjs Curator/scripts/auto_config_mcp.py",
    "capa1:install": "node \"Capa 1/scripts/instalar-capa1-completa.mjs\"",
    "capa1:verify": "node \"Capa 1/scripts/verificar-capa1.mjs\"",
    "mcp:doctor": "node scripts/mcp-doctor.mjs",
    "mcp:ci": "node scripts/verify-mcp-ci.mjs",
    "mcp:observability": "node scripts/verify-mcp-observability.mjs",
    "mcp:handshake": "node scripts/verify-mcp-handshake.mjs",
    "mcp:uma-recall": "node scripts/verify-mcp-uma-recall.mjs",
    "mcp:p5": "node scripts/verify-mcp-p5.mjs",
    "mcp:p6": "node scripts/verify-mcp-p6.mjs",
    "mcp:contract": "node scripts/verify-mcp-contract.mjs",
    "mcp:health": "node scripts/verify-mcp-health.mjs",
    "mcp:clients": "node scripts/verify-mcp-clients.mjs",
    "mcp:amplifier": "node scripts/verify-mcp-amplifier.mjs",
    "mcp:delegate": "node scripts/verify-delegate-api.mjs",
    "sognatore:dispatch-verify": "node scripts/verify-dispatch-cli.mjs",
    "sognatore:worker-verify": "node scripts/verify-worker-queue.mjs",
    "sognatore:dept-verify": "node scripts/verify-dept-agent-bridge.mjs",
    "ollama:doctor": "node scripts/ollama-doctor.mjs",
    "redis:up": "docker compose -f docker/docker-compose.yml up -d redis",
    "redis:down": "docker compose -f docker/docker-compose.yml stop redis",
    "redis:ping": "node scripts/redis-probe.mjs",
    "redis:logs": "docker compose -f docker/docker-compose.yml logs --tail=50 redis",
    "worker:start": "node scripts/worker-celery.mjs start",
    "worker:stop": "node scripts/worker-celery.mjs stop",
    "worker:status": "node scripts/worker-celery.mjs status",
    "sogna:on": "node control/sogna.mjs on",
    "sogna:off": "node control/sogna.mjs off",
    "sogna:health": "node control/sogna.mjs health",
    "sogna:check": "node control/sogna.mjs check",
    "corners:deploy": "node scripts/deploy-corners.mjs",
    "corners:verify": "node scripts/verify-corners.mjs",
    "postinstall": "node Curator/scripts/node_sanitizer.js"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "**/*.{ts,js}": [
      "pnpm sentinel:veto"
    ],
    ".veglia/*": [
      "pnpm sentinel:veto"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "protobufjs"
    ],
    "overrides": {
      "serialize-javascript": "^7.0.3",
      "@anthropic-ai/sdk": ">=0.91.1",
      "esbuild": ">=0.28.1",
      "prismjs@<1.30.0": ">=1.30.0",
      "postcss@<8.5.10": ">=8.5.10",
      "rollup-plugin-sourcemaps>rollup": ">=4.0.0",
      "@anthropic-ai/claude-agent-sdk>zod": ">=3.25.76",
      "protobufjs": ">=7.5.8",
      "@grpc/grpc-js": ">=1.14.4",
      "ws": ">=8.20.1",
      "turbo": ">=2.9.14",
      "uuid": ">=11.1.1",
      "qs": ">=6.15.2",
      "hono": ">=4.12.21",
      "@ai-sdk/provider-utils": ">=4.0.29",
      "ai": ">=6.0.205",
      "unrun": "0.2.39",
      "@mozilla/readability": ">=0.6.0",
      "@modelcontextprotocol/sdk": ">=1.25.2",
      "form-data": ">=4.0.6",
      "vite": ">=8.0.16",
      "js-yaml": ">=4.2.0",
      "@babel/core": ">=7.29.6",
      "@opentelemetry/core": ">=1.30.2",
      "mcp-remote>undici": ">=7.28.0",
      "@vercel/blob>undici": ">=7.28.0"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "rollup"
      ],
      "allowedVersions": {
        "rollup-plugin-sourcemaps": "*"
      }
    }
  },
  "devDependencies": {
    "@kwp-lab/mcp-fetch": "^0.9.5",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@modelcontextprotocol/server-github": "^2025.4.8",
    "globals": "catalog:",
    "lint-staged": "catalog:",
    "mcp-remote": "^0.1.38",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
