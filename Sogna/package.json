{
  "name": "sogna",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "sogna_governance": "./.sognarc.json",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "prepare": "husky Curator/engines/Sentinel/.husky",
    "sogna:dev": "vite",
    "sogna:start": "node Curator/bin/Sogna.js",
    "sogna:dream": "node Curator/bin/dream.js",
    "sognatore:core": "node Curator/bin/Sognatore.js",
    "sentinel:audit": "python Curator/engines/Sentinel/Sentinel-doctor.py",
    "sentinel:veto": "node Curator/engines/Sentinel/bin/Sentinel-veto.js",
    "memory:sync": "node Curator/bin/memory_sync.js"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "**/*.{ts,js}": [
      "npm run sentinel:veto"
    ],
    "Curator/engines/Sentinel/.husky/*": [
      "npm run sentinel:veto"
    ]
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": "^7.0.3",
      "@anthropic-ai/sdk": ">=0.91.1",
      "esbuild@<=0.24.2": ">=0.25.0",
      "prismjs@<1.30.0": ">=1.30.0",
      "postcss@<8.5.10": ">=8.5.10",
      "rollup-plugin-sourcemaps>rollup": ">=4.0.0",
      "@anthropic-ai/claude-agent-sdk>zod": ">=3.25.76"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "rollup"
      ],
      "allowedVersions": {
        "rollup-plugin-sourcemaps": "*"
      }
    }
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "chalk": "catalog:",
    "concurrently": "catalog:",
    "framer-motion": "catalog:",
    "husky": "catalog:",
    "jest": "catalog:",
    "lint-staged": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "catalog:",
    "rollup": "catalog:",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-preserve-directives": "^0.4.0",
    "rollup-plugin-sourcemaps": "^0.6.3",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
