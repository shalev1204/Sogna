{
  "name": "@Assembler/agent",
  "version": "0.0.6",
  "license": "MIT",
  "description": "Define AI agents and tools with full type inference for Assembler Agents",
  "homepage": "https://Assembler.dev/agents",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "docs/**/*",
    "src",
    "!src/**/*.test.ts",
    "AGENTS.md",
    "LICENSE",
    "README.md"
  ],
  "directories": {
    "doc": "./docs"
  },
  "keywords": [
    "ai",
    "agent",
    "tools",
    "Assembler",
    "Assembler.dev",
    "sdk",
    "claude",
    "codex"
  ],
  "scripts": {
    "prepack": "cp -r ../docs ./docs",
    "postpack": "rm -rf ./docs",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": ">=3.24"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "zod": "^3.24"
  }
}
