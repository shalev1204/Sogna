{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ESNext",
    "moduleDetection": "force",
    "allowJs": true
  },
  "include": ["vite.config.ts", "package.json"]
}
