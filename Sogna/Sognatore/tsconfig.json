{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@sogna/curator": ["../Curator/index.ts"],
      "@sogna/curator/*": ["../Curator/*"]
    }
  },
  "include": [
    "src/**/*",
    "../toolkit/shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "resources/templates"
  ]
}
