{
  "layers": {
    "identity": {
      "weight": 1.0,
      "path": "identity",
      "files": [
        "index_uma.py",
        "prune.py",
        "query_memory.py",
        "reflect.py",
        "registry.json",
        "rules.md",
        "sogna.md",
        "strategic_intent.md",
        "uma-doctor.py",
        "user_profile.md"
      ],
      "description": "Core system behaviors, personality, and strategic intent"
    },
    "immunological": {
      "weight": 0.9,
      "path": "intelligence/security",
      "description": "Threat patterns, learned threats, and security intelligence"
    },
    "semantic": {
      "weight": 0.8,
      "path": "intelligence/semantic",
      "description": "Generalized facts, rules, and design tokens extracted from experience"
    },
    "episodic": {
      "weight": 0.6,
      "path": "intelligence/episodic",
      "description": "Specific past project solutions and reflective logs"
    },
    "operational": {
      "weight": 0.4,
      "path": "operational/agent",
      "description": "Active session context and agent-specific temporary data"
    },
    "navigator": {
      "weight": 0.5,
      "path": "operational/navigator",
      "description": "Project mapping and exploration data"
    },
    "designs": {
      "weight": 0.7,
      "path": "designs",
      "description": "UI/UX reasoning, master design files, and aesthetic memory"
    },
    "logs": {
      "weight": 0.3,
      "path": "operational/logs",
      "description": "Operational history and systemic event logs"
    },
    "synapses": {
      "weight": 0.5,
      "path": "operational/synapses",
      "description": "Cross-engine behavioral connections and synchronization links"
    },
    "documentation": {
      "weight": 0.4,
      "path": "docs",
      "description": "Architecture reports, protocols, and technical manuals"
    }
  },
  "synthesis": {
    "target": "identity/sogna.md",
    "trigger_count": 50,
    "current_reflection_count": 1,
    "archive_after_days": 30,
    "reflection_interval": "daily"
  },
