# ==============================================================================

# SOGNA — Plantilla de entorno (.env.example)

# Copie a .env y rellene valores. Nunca commitear .env.

# Modo local-first: ninguna clave es obligatoria si intelligence.mode=local.

# ==============================================================================



# @optional SOGNA_MCP_HOST

# @optional SOGNA_UMA_API_PORT

# @optional SOGNA_MCP_UMA_PORT

# @optional SOGNA_MCP_BRIDGE_PORT

# @optional SOGNA_WEB_PORT

# @optional SOGNA_MCP_ALLOW_WRITE

# @optional SOGNA_DELEGATE_API_TOKEN

# @optional SOGNA_MCP_TOKEN



# === Modo inteligencia (local por defecto en .sognarc.json) ===

# @optional SOGNA_LOCAL_MODE

# @optional SOGNATORE_KEYLESS

# @optional SOGNATORE_ALLOW_CLOUD



# === Cloud — @required solo si intelligence.mode es hybrid o cloud ===

# @required ANTHROPIC_API_KEY

# @optional OPENAI_API_KEY

# @optional GOOGLE_API_KEY

# @optional GEMINI_API_KEY



# === Supabase — Sogna Core F0 (memoria vectorial UMA) ===

# Dashboard → Project Settings → API

# @recommended SUPABASE_URL

# @recommended SUPABASE_ANON_KEY

# @recommended SUPABASE_SERVICE_ROLE_KEY

# Dashboard → Database → Connection string → URI

# @recommended SUPABASE_DB_URL

# @optional SUPABASE_DB_DIRECT_URL

# @optional SOGNA_VECTOR_PROVIDER

# @optional SOGNA_INFRA_PHASE



# SUPABASE_URL=https://xxxxxxxx.supabase.co

# SUPABASE_ANON_KEY=eyJ...

# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# SUPABASE_DB_DIRECT_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# SOGNA_VECTOR_PROVIDER=supabase



# === Integraciones opcionales ===

# @optional NOTION_TOKEN

# @optional SOGNATORE_JIRA_URL

# @optional SOGNATORE_JIRA_EMAIL

# @optional SOGNATORE_JIRA_TOKEN

# @optional SOGNATORE_LINEAR_TOKEN

# @optional SOGNATORE_GITHUB_SYNC



# === Redis + Celery — Sogna Core F0 ===

# Redis local vía Docker (pnpm redis:up)
# @recommended REDIS_URL

# REDIS_URL=redis://localhost:6379/0

# Celery concurrencia (defecto: 2 procesos)
# @optional SOGNA_CELERY_CONCURRENCY

# Celery log level (defecto: info)
# @optional SOGNA_CELERY_LOGLEVEL



# === OpenTelemetry — Observabilidad F0 ===

# Nombre del servicio en trazas (defecto: sogna-uma)
# @optional OTEL_SERVICE_NAME

# Versión del servicio (defecto: 0.1.0)
# @optional OTEL_SERVICE_VERSION

# Entorno de despliegue: local | staging | production (defecto: local)
# @optional OTEL_DEPLOYMENT_ENVIRONMENT

# URL del colector OTLP HTTP. Vacío = ConsoleSpanExporter (local dev).
# Grafana Cloud: https://otlp-gateway-prod-eu-west-0.grafana.net/otlp
# @optional OTEL_EXPORTER_OTLP_ENDPOINT

# Headers CSV para autenticación OTLP. Grafana Cloud: Authorization=Bearer <TOKEN>
# @optional OTEL_EXPORTER_OTLP_HEADERS

# Desactivar OTel completamente (útil en tests). true | false (defecto: false)
# @optional OTEL_SDK_DISABLED

# OTEL_SERVICE_NAME=sogna-uma
# OTEL_SERVICE_VERSION=0.1.0
# OTEL_DEPLOYMENT_ENVIRONMENT=local
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=
# OTEL_SDK_DISABLED=false



# === Ollama / worker local ===

# @optional SOGNA_OLLAMA_JOB_TIMEOUT_MS

# @optional SOGNA_WORKER_MAX_SCRIPT

# @optional SOGNA_WORKER_MAX_OLLAMA

