# ==============================================================================
# SOGNA — Plantilla de entorno (.env.example)
# Copie a .env y rellene valores. Nunca commitear .env.
# Modo local-first: ninguna clave es obligatoria si intelligence.mode=local.
# ==============================================================================

# @optional SOGNA_MCP_HOST
# @optional SOGNA_UMA_API_PORT
# @optional SOGNA_MCP_UMA_PORT
# @optional SOGNA_MCP_BRIDGE_PORT
# @optional SOGNA_WEB_PORT
# @optional SOGNA_MCP_ALLOW_WRITE
# @optional SOGNA_DELEGATE_API_TOKEN
# @optional SOGNA_MCP_TOKEN

# === Modo inteligencia (local por defecto en .sognarc.json) ===
# @optional SOGNA_LOCAL_MODE
# @optional SOGNATORE_KEYLESS
# @optional SOGNATORE_ALLOW_CLOUD

# === Cloud — @required solo si intelligence.mode es hybrid o cloud ===
# @required ANTHROPIC_API_KEY
# @optional OPENAI_API_KEY
# @optional GOOGLE_API_KEY
# @optional GEMINI_API_KEY

# === Integraciones opcionales (misma cuenta en todos sus dispositivos) ===
# @optional SUPABASE_URL
# @optional SUPABASE_ANON_KEY
# @optional SUPABASE_SERVICE_ROLE_KEY
# @optional NOTION_TOKEN
# @optional SOGNATORE_JIRA_URL
# @optional SOGNATORE_JIRA_EMAIL
# @optional SOGNATORE_JIRA_TOKEN
# @optional SOGNATORE_LINEAR_TOKEN
# @optional SOGNATORE_GITHUB_SYNC

# === Ollama / worker local ===
