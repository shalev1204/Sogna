{
  "project": "Sogna",
  "version": "0.1.0",
  "slogan": "Build for the Second One",
  "environment": "Development/Beta",
  "securityTier": "max",
  "strictMode": true,
  "anonymizeLogs": true,
  "privacy_shield": {
    "redact_pii": true,
    "redact_secrets": true,
    "custom_redactions": {
      "carle": "[OPERATOR]"
    }
  },
  "agent_guidelines": {
    "user_interaction": {
      "address_as": "Operador",
      "honorifics": "Usted",
      "tone": "Institutional/Professional",
      "language": "es-ES"
    }
  },
  "integration_mapping": {
    "scripts_reference": "./package.json",
    "command_rules": {
      "sogna:dev": { "permission": "development", "require_network": true },
      "sogna:start": { "permission": "operational", "require_vitals": "healthy" },
      "sentinel:audit": { "permission": "security", "elevation_required": true },
      "sognatore:core": { "permission": "orchestration", "cpu_priority": "high" },
      "memory:sync": { "permission": "data_integrity", "disk_access": "full" }
    }
  },
  "governance": {
    "audit_trail": "enabled",
    "require_human_approval_for_destructive_actions": true,
    "require_veto_on_commit": true,
    "log_level": "verbose"
  },
  "operational_bounds": {
    "git_auto_commit": false,
    "shell_deep_vetting": true,
    "binary_hygiene": true,
    "max_read_size_bytes": 2097152,
    "max_output_size_chars": 16384,
    "execution_timeout_ms": 300000,
    "allowed_directories": [
      ".",
      "./memory",
      "./Sognatore",
      "./Curator",
      "./docs"
    ]
  },
  "swarm_protocols": {
    "multi_agent_collaboration": true,
    "conflict_resolution": "deterministic",
    "shared_context_path": "./.sogna_context",
    "agent_hierarchy": {
      "leader": "Antigravity",
      "orchestrator": "Sognatore",
      "specialists": ["Sentinel", "Animator", "Predatore", "Curator"]
    },
    "messaging": {
      "protocol": "UMA-Bridge",
      "async_mode": true,
      "broadcast_events": ["security_alert", "task_completion", "health_critical"]
    },
    "handoff_logic": {
      "require_validation": true,
      "state_persistence": "enabled"
    }
  },
  "resource_quotas": {
    "max_cpu_usage_percent": 80,
    "max_memory_usage_mb": 8192,
    "disk_space_threshold_percent": 90,
    "budget_limits": {
      "max_tokens": 1500000,
      "alerts": [50, 80, 100],
      "on_exceed": "shutdown"
    }
  },
  "intelligence": {
    "mode": "local",
    "local_provider": "ollama",
    "cloud_provider": null,
    "worker_profile": "background",
    "routing_rules": {
      "coding": "ollama:deepseek-coder-v2:lite",
      "debugging": "ollama:qwen2.5-coder:7b",
      "testing": "ollama:qwen2.5-coder:7b",
      "documentation": "ollama:gemma2:9b",
      "architecture": "ollama:gemma2:9b",
      "security": "ollama:qwen2.5-coder:7b",
      "system": "ollama:llama3.1:latest"
    }
  }
}