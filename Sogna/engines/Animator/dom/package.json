{
"name": "sognaflow-dom",
    "version": "12.38.0",
    "author": "Matt Perry",
    "license": "MIT",
    "repository": "https://github.com/sognaflowdivision/sognaflow",
    "main": "./dist/cjs/index.js",
    "types": "./dist/index.d.ts",
    "module": "./dist/es/index.mjs",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/cjs/index.js",
            "import": "./dist/es/index.mjs",
            "default": "./dist/cjs/index.js"
        }
    },
    "dependencies": {
        "sognaflow-utils": "workspace:*",
        "tslib": "^2.8.1"
    },
    "scripts": {
        "clean": "node -e \"const fs = require('fs'); ['dist'].forEach(d => fs.rmSync(d, { recursive: true, force: true }))\"",
        "build": "pnpm clean && rollup -c && node ./scripts/check-bundle.js",
        "dev": "concurrently -c blue,red -n tsc,rollup --kill-others \"tsc --watch -p . --preserveWatchOutput\" \"rollup --config --watch --no-watch.clearScreen\"",
        "test": "jest --config jest.config.json --max-workers=2",
        "measure": "rollup -c ./rollup.size.config.mjs"
    },
    "bundlesize": [
        {
            "path": "./dist/size-rollup-style-effect.js",
            "maxSize": "2.9 kB"
        },
        {
            "path": "./dist/size-rollup-sognaflow-value.js",
            "maxSize": "1.8 kB"
        }
    ],
    "gitHead": "0d3c11b5f54647ecc5d1ee93e827651291fe7ce3",
    "devDependencies": {
        "@thednp/dommatrix": "^2.0.12",
        "@rollup/plugin-node-resolve": "catalog:",
        "@rollup/plugin-replace": "catalog:",
        "@rollup/plugin-terser": "catalog:",
        
        "jest": "catalog:",
        "ts-jest": "catalog:",
        "jest-environment-jsdom": "catalog:",
        "jest-watch-typeahead": "catalog:",
        "jest-junit": "catalog:",
        "@types/jest": "catalog:",
        
        "rollup": "catalog:",
        "rollup-plugin-dts": "catalog:",
        "rollup-plugin-preserve-directives": "catalog:",
        "rollup-plugin-sourcemaps": "catalog:",
        "typescript": "catalog:"
    }
}

