{
"name": "@Assembler/nextjs",
  "version": "0.0.10",
  "license": "MIT",
"description": "Next.js integration for Assembler Agents chat",
  "homepage": "https://Assembler.dev/agents",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    }
  },
  "files": [
    "dist",
    "docs/**/*",
    "src",
    "!src/**/*.test.ts",
    "AGENTS.md",
    "LICENSE",
    "README.md"
  ],
  "directories": {
    "doc": "./docs"
  },
  "keywords": [
    "nextjs",
    "react",
    "ai",
    "agent",
    "chat",
    "ai-sdk",
    "Assembler",
    "Assembler.dev"
  ],
  "scripts": {
    "prepack": "cp -r ../docs ./docs",
    "postpack": "rimraf ./docs",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@Assembler/react": "workspace:*",
    "@ai-sdk/react": "^3.0.0",
    "ai": "^6.0.0",
    "next": ">=14.0.0",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@Assembler/react": "workspace:*",
    "@types/react": "catalog:",
    "next": "^15.5.18",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsup": "^8.5.1",
    "typescript": "catalog:"
  }
}
