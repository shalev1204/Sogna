{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false,

    /* Sincronización Arquitectónica */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@core/*": ["Sognatore/src/core/*"],
      "@engines/*": ["engines/*"],
      "@shared/*": ["Curator/shared/*"],
      "@memory/*": ["Sognatore/src/core/memory/*"]
    },

    "allowImportingTsExtensions": true
  },
  "include": ["src", "Sognatore/src", "engines", "Curator/lab"]
}
