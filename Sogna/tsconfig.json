{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Sincronización Arquitectónica */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@core/*": ["Sognatore/src/core/*"],
      "@engines/*": ["Curator/engines/*"],
      "@shared/*": ["Curator/shared/*"],
      "@memory/*": ["Sognatore/src/core/memory/*"]
    },

    /* Optimización y Modernización */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,

    /* Rigor Multi-plataforma (Windows/Mac) */
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "Sognatore/src", "Curator/engines"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
