{
  "name": "@Assembler/cli",
  "version": "0.0.15",
  "description": "CLI for deploying AI agents to Assembler Agents",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "an": "dist/index.js"
  },
  "files": [
    "dist",
    "docs/**/*",
    "src",
    "!src/**/*.test.ts",
    "AGENTS.md",
    "README.md"
  ],
  "directories": {
    "doc": "./docs"
  },
  "scripts": {
    "prepack": "cp -r ../docs ./docs",
    "postpack": "rimraf ./docs",
    "build": "tsup",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "esbuild": "^0.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
