{
  "name": "@Assembler/react",
  "version": "0.1.4",
  "license": "MIT",
  "description": "React components for Assembler Agents chat UIs",
  "homepage": "https://Assembler.dev/agents",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./styles/index.css": "./styles/index.css"
  },
  "files": [
    "dist",
    "docs/**/*",
    "styles",
    "src",
    "!src/**/*.test.ts",
    "AGENTS.md",
    "LICENSE",
    "README.md"
  ],
  "directories": {
    "doc": "./docs"
  },
  "keywords": [
    "react",
    "ai",
    "agent",
    "chat",
    "ai-sdk",
    "Assembler",
    "Assembler.dev",
    "components",
    "ui"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "scripts": {
    "prepack": "cp -r ../docs ./docs",
    "postpack": "rimraf ./docs",
    "build": "tsup && tailwindcss -i styles/index.css -o dist/styles.css --minify",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@ai-sdk/react": "^2.0.0",
    "ai": "^5.0.0",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "motion": "^12.38.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.6",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.1"
  },
  "devDependencies": {
    "@ai-sdk/react": "^2.0.187",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-syntax-highlighter": "^15.5.13",
    "ai": "^5.0.185",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "^3.4.19",
    "tsup": "^8.5.1",
    "typescript": "catalog:"
  }
}
