{
"name": "@Assembler/node",
  "version": "0.0.4",
  "license": "MIT",
"description": "Server-side Node.js SDK for Assembler Agents",
  "homepage": "https://Assembler.dev/agents",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "docs/**/*",
    "src",
    "!src/**/*.test.ts",
    "AGENTS.md",
    "LICENSE",
    "README.md"
  ],
  "directories": {
    "doc": "./docs"
  },
  "keywords": [
    "ai",
    "agent",
    "sandbox",
    "Assembler",
    "Assembler.dev",
    "sdk",
    "node"
  ],
  "scripts": {
    "prepack": "cp -r ../docs ./docs",
    "postpack": "rimraf ./docs",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
