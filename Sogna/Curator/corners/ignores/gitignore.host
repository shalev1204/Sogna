# ==============================================================================
# SOGNA — .gitignore (raíz git del host, layout embedded: repo/Sogna/)
# SSOT: Curator/corners/ignores/gitignore.host
# Deploy: scripts/deploy-corners.ps1
#
# Política: secretos + runtime efímero + artefactos regenerables (pnpm/cargo).
# VERSIONADO vía GitHub (pull = máquinas a la par):
#   memory/, .sognatore/, snapshots episódicos, .cursor/.claude/.agents rules,
#   platform state — NO listar aquí.
# ==============================================================================

# --- TIER 1: SECRETOS (nunca commitear) ---
.env
.env.*
!.env.example
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
credentials/
**/memory/operational/vault/
**/secrets/
**/*-credentials.json
**/service-account*.json

# Tokens locales de IDE (Capa 1 del Operador en máquina)
**/.claude/settings.local.json
**/.cursor/mcp.json
.mcp.json

# --- TIER 2: RUNTIME EFÍMERO (no es estado de proceso) ---
Sogna/Sentinel/.sentinel_veto_tmp.json
Sogna/Sentinel/.veto_tmp/
Sogna/Sentinel/.cold_run_sim/

# --- TIER 3: REGENERABLES (pnpm install / build — no sincronizar) ---
node_modules/
.pnpm-store/
dist/
build/
!Sogna/Sognatore/resources/skills/utilities/build/
.next/
.turbo/
.vercel/
target/
**/*.pdb
**/*.exe
**/*.rlib
**/*.rmeta
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
.pytest_cache/
*.tgz
coverage/
test-results/
playwright-report/

# --- TIER 4: OS / editor swap ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- TIER 5: LOGS (PII/secretos accidentales) ---
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
pip-log.txt

# --- Artefactos locales de auditoría (regenerables) ---
.audit-report.json
