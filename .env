# SOGNA - Environment Configuration Template
# ---------------------------------------------------------
# Copy this file to .env and fill in your credentials.
# WARNING: Never commit the actual .env file with real keys.

# --- AI PROVIDERS ---
# Anthropic (Main Reasoning)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini (High-Speed / Massive Context)
GEMINI_API_KEY=AIzaSyDfqcSZzGNvsdk_1DkBDxcP3zIwr2voa50

# OpenAI (Alternative Reasoning)
OPENAI_API_KEY=sk-your-openai-key-here

# --- DATABASE (Supabase) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- SOGNATORE SOVEREIGN CORE ---
# IMPORTANT: GUARDIAN_SECRET is your master encryption key.
# Use a random 32+ character string. Sognatore uses this to seal agent state.
GUARDIAN_SECRET=K9vP2wR7xL4mN8bQ5zT1yH6uJ3cA9fG4

# Sandbox Configuration
SOGNATORE_SANDBOX_ENABLED=true
DOCKER_IMAGE_NAME=sognatore-sovereign:latest

# Operational Limits
SOGNATORE_MAX_ITERATIONS=20
DEBUG_LEVEL=info # options: debug, info, warn, error
STRESS_TEST=false

# Root directory of the Sognatore core (Internal Use)
SOGNATORE_ROOT=./Sogna/Sognatore
